{
  "name": "memora",
  "private": true,
  "packageManager": "pnpm@9.12.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @memora/api --filter @memora/web run dev",
    "dev:api": "pnpm --filter @memora/api dev",
    "dev:web": "pnpm --filter @memora/web dev",
    "build": "pnpm --filter @memora/api --filter @memora/web run build",
    "build:api": "pnpm --filter @memora/api build",
    "build:web": "pnpm --filter @memora/web build",
    "start": "pnpm --filter @memora/api start",
    "db:generate": "pnpm --filter @memora/api db:generate",
    "db:migrate": "pnpm --filter @memora/api db:migrate",
    "db:push": "pnpm --filter @memora/api db:push"
  }
}
